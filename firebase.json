{
  "hosting": [
    {
      "target": "main",
      "public": "apps/toki-website/out",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ]
    },
    {
      "target": "legacy",
      "public": "apps/toki-website-legacy/out",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ]
    }
  ]
}
